<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">
    <ScrollView>
        <ScrollView.Background>
            <SolidColorBrush Color="{AppThemeBinding Light=#FAFAF3, Dark=#0F1711}" />
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#8A7A6A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="Theme mode"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                        <Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Choose app theme"
                                SelectedIndexChanged="OnThemeChanged"
                                SemanticProperties.Hint="Switch between system, light, and dark theme">
                            <Picker.Items>
                                <x:String>Use system theme</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Large text mode"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                            <Label Text="Increase text size for accessibility demonstration."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Increase text size across the current session" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF0BC, Dark=#4A3417}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="When enabled, this text and the rest of the page become visibly larger."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Hardware Test (for demo)"
                    BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                    TextColor="#FFFFFF"
                    FontAttributes="Bold"
                    Clicked="OnHardwareTestClicked"
                    Margin="0,16,0,0" />

            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
