<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <ScrollView>
        <ScrollView.Background>
            <SolidColorBrush Color="{AppThemeBinding Light=#FAFAF3, Dark=#0F1711}" />
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="{AppThemeBinding Light=#FFF0BC, Dark=#4A3417}" />
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <Label x:Name="NameLabel"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" /> 
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#8A7A6A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition overview" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                    <Label x:Name="MacroLabel" FontSize="16" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />
                    <Label x:Name="DescriptionLabel" FontSize="15" TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="AllergyLabel" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                </VerticalStackLayout>
            </Border>

            <!-- Photo Section -->
            <Border x:Name="PhotoSection"
                    IsVisible="False"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Food Photo" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                            HeightRequest="200">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="DetailPhoto" Aspect="AspectFill" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Location Section -->
            <Border x:Name="LocationSection"
                    IsVisible="False"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Meal Location" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                    <Label x:Name="DetailLocation" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read summary"
                        BackgroundColor="{AppThemeBinding Light=#FFBF53, Dark=#FBB611}"
                        TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#261307}"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                        BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#8A7A6A}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
