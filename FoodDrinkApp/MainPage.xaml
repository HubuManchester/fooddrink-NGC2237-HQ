<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             xmlns:converters="clr-namespace:FoodDrinkApp.Converters"
             x:Class="FoodDrinkApp.MainPage"
             Title="Today's Meal">
    <ContentPage.Resources>
        <converters:CategoryToColorConverter x:Key="CategoryToColorConverter" />
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <SolidColorBrush Color="{AppThemeBinding Light=#FAFAF3, Dark=#0F1711}" />
        </Grid.Background>

        <Grid Padding="20,18,20,18">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="{AppThemeBinding Light=#FFF0BC, Dark=#4A3417}" />
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.45" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,6,0,0">
                        <Border StrokeThickness="1"
                                Stroke="#FFE0BA"
                                BackgroundColor="#FFFFFA"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#3A2518"
                                       PlaceholderColor="#9A7B63"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="{AppThemeBinding Light=#83B271, Dark=#478E38}"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>

                    <Button Grid.Row="1"
                            Text="Randomly recommend delicious food"
                            BackgroundColor="{AppThemeBinding Light=#FFBF53, Dark=#FBB611}"
                            TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#261307}"
                            FontAttributes="Bold"
                            Clicked="OnRandomPickClicked"
                            Margin="0,8,0,0"
                            SemanticProperties.Hint="Randomly recommend a dish or drink" />
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1" 
             x:Name="FoodRefreshView" 
             Refreshing="OnRefreshing"
             Margin="20,0,18,0">
            <CollectionView x:Name="FoodCollection"
                    SelectionMode="None"
                    EmptyView="No matching food or drink records."
                    Margin="0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#8A7A6A}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                        Padding="0"
                        Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,5" Radius="14" Opacity="0.34" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="6,*">
                                <BoxView BackgroundColor="{Binding Category, Converter={StaticResource CategoryToColorConverter}}" />
                                <Grid Grid.Column="1" Padding="16" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                                    <Label Text="{Binding Name}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                                   SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#4A3417}"
                                            Padding="10,5"
                                            HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <Label Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                                   LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding MacroSummary}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding Category}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                                        <Button Grid.Column="1"
                                        Text="Details"
                                        Padding="14,8"
                                        BackgroundColor="{AppThemeBinding Light=#FFBF53, Dark=#FBB611}"
                                        TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#261307}"
                                        CommandParameter="{Binding Id}"
                                        Clicked="OnDetailsClicked"
                                        SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
